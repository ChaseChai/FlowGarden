# 分身农庄 - 环境变量模板
# 复制为 .env 并填入实际值

# 戒指 MAC 地址
RING_MAC=F1:C1:8A:35:40:FB

# 演示模式（1=不接戒指，模拟事件）
DEMO_MODE=1

# LLM API（Claude/GPT）
LLM_API_KEY=sk-xxx
LLM_MODEL=claude-sonnet-4-20250514
